<mapper namespace="com.smart.campus.mappers.FacultyInfoMapper">

	<!--实体映射-->
	<resultMap id="base_result_map" type="com.smart.campus.entity.po.FacultyInfo">
		<!---->
		<id column="faculty_id" property="facultyId"  />
		<!--院系名称-->
		<result column="faculty_name" property="facultyName"  />
		<!--院系编码（唯一）-->
		<result column="faculty_code" property="facultyCode"  />
		<!--院系描述-->
		<result column="description" property="description"  />
		<!--排序权重-->
		<result column="sort_order" property="sortOrder"  />
		<!--创建时间-->
		<result column="create_time" property="createTime"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 f.faculty_id,f.faculty_name,f.faculty_code,f.description,f.sort_order,
		 f.create_time
	</sql>

	<sql id="base_condition_filed">
			<if test="query.facultyId != null">
				 and  f.faculty_id = #{query.facultyId}
			</if>
			<if test="query.facultyName != null and query.facultyName!=''">
				 and  f.faculty_name = #{query.facultyName}
			</if>
			<if test="query.facultyCode != null and query.facultyCode!=''">
				 and  f.faculty_code = #{query.facultyCode}
			</if>
			<if test="query.description != null and query.description!=''">
				 and  f.description = #{query.description}
			</if>
			<if test="query.sortOrder != null">
				 and  f.sort_order = #{query.sortOrder}
			</if>
			<if test="query.createTime != null and query.createTime!=''">
				 <![CDATA[ and  f.create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
			</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.facultyNameFuzzy!= null  and query.facultyNameFuzzy!=''">
				 and  f.faculty_name like concat('%', #{query.facultyNameFuzzy}, '%')
			</if>
			<if test="query.facultyCodeFuzzy!= null  and query.facultyCodeFuzzy!=''">
				 and  f.faculty_code like concat('%', #{query.facultyCodeFuzzy}, '%')
			</if>
			<if test="query.descriptionFuzzy!= null  and query.descriptionFuzzy!=''">
				 and  f.description like concat('%', #{query.descriptionFuzzy}, '%')
			</if>
			<if test="query.createTimeStart!= null and query.createTimeStart!=''">
				 <![CDATA[ and  f.create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
				 <![CDATA[ and  f.create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
	 </where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM faculty_info f <include refid="query_condition" />
		 <if test="query.orderBy!=null">
			 order by ${query.orderBy}
		 </if>
		 <if test="query.simplePage!=null">
			 limit #{query.simplePage.start},#{query.simplePage.end}
		 </if>
	</select>

	<!-- 查询数量-->
	<select id="selectCount" resultType="java.lang.Integer" >
