	</insert>

	<!-- 插入或者更新 （匹配有值的字段）-->
	<insert id="insertOrUpdate" parameterType="com.smart.campus.entity.po.FacultyInfo">
		 INSERT INTO faculty_info
		 <trim prefix="(" suffix=")" suffixOverrides=",">
