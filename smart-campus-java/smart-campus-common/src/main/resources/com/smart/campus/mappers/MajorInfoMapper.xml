	<!--实体映射-->
	<resultMap id="base_result_map" type="com.smart.campus.entity.po.MajorInfo">
		<!---->
		<id column="major_id" property="majorId"  />
		<!--专业名称-->
		<result column="major_name" property="majorName"  />
		<!--专业编码（唯一）-->
		<result column="major_code" property="majorCode"  />
		<!--所属院系ID-->
		<result column="faculty_id" property="facultyId"  />
		<!--所属院系名称（关联查询）-->
		<result column="faculty_name" property="facultyName"  />
		<!--专业描述-->
		<result column="description" property="description"  />
		<!--排序权重-->
		<result column="sort_order" property="sortOrder"  />
		<!--创建时间-->
		<result column="create_time" property="createTime"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 m.major_id,m.major_name,m.major_code,m.faculty_id,fa.faculty_name,
		 m.description,m.sort_order,m.create_time
	</sql>

	<sql id="base_condition_filed">
			<if test="query.majorId != null">
				 and  m.major_id = #{query.majorId}
			</if>
			<if test="query.majorName != null and query.majorName!=''">
				 and  m.major_name = #{query.majorName}
			</if>
			<if test="query.majorCode != null and query.majorCode!=''">
				 and  m.major_code = #{query.majorCode}
			</if>
			<if test="query.facultyId != null">
				 and  m.faculty_id = #{query.facultyId}
			</if>
			<if test="query.description != null and query.description!=''">
				 and  m.description = #{query.description}
			</if>
			<if test="query.sortOrder != null">
				 and  m.sort_order = #{query.sortOrder}
			</if>
			<if test="query.createTime != null and query.createTime!=''">
				 <![CDATA[ and  m.create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
			</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.majorNameFuzzy!= null  and query.majorNameFuzzy!=''">
				 and  m.major_name like concat('%', #{query.majorNameFuzzy}, '%')
			</if>
			<if test="query.majorCodeFuzzy!= null  and query.majorCodeFuzzy!=''">
				 and  m.major_code like concat('%', #{query.majorCodeFuzzy}, '%')
			</if>
			<if test="query.descriptionFuzzy!= null  and query.descriptionFuzzy!=''">
				 and  m.description like concat('%', #{query.descriptionFuzzy}, '%')
			</if>
			<if test="query.createTimeStart!= null and query.createTimeStart!=''">
				 <![CDATA[ and  m.create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
				 <![CDATA[ and  m.create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
	 </where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM major_info m
		 LEFT JOIN faculty_info fa ON m.faculty_id = fa.faculty_id
		 <include refid="query_condition" />
		 <if test="query.orderBy!=null">
			 order by ${query.orderBy}
		 </if>
		 <if test="query.simplePage!=null">
			 limit #{query.simplePage.start},#{query.simplePage.end}
		 </if>
	</select>

	<!-- 查询数量-->
	<select id="selectCount" resultType="java.lang.Integer" >
		 SELECT count(1) FROM major_info m <include refid="query_condition" />
	</select>

