<mapper namespace="com.smart.campus.mappers.QuestionInfoMapper">

	<!--实体映射-->
	<resultMap id="base_result_map" type="com.smart.campus.entity.po.QuestionInfo">
		<!--习题ID（UUID）-->
		<result column="question_id" property="questionId"  />
		<!--题干内容-->
		<result column="question_title" property="questionTitle"  />
		<!--题型：1-单选题, 2-多选题, 3-判断题, 4-简答题-->
		<result column="question_type" property="questionType"  />
		<!--难度：1-简单, 2-中等, 3-困难-->
		<result column="difficulty" property="difficulty"  />
		<!--正确答案（客观题存选项key如A/B/AB，主观题存参考答案文本，判断题存T/F）-->
		<result column="answer" property="answer"  />
		<!--答案解析-->
		<result column="analysis" property="analysis"  />
		<!--默认分值-->
		<result column="score" property="score"  />
		<!--创建人用户ID-->
		<result column="create_user_id" property="createUserId"  />
		<!--排序权重-->
		<result column="sort_order" property="sortOrder"  />
		<!--创建时间-->
		<result column="create_time" property="createTime"  />
		<!--更新时间-->
		<result column="update_time" property="updateTime"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 q.question_id,q.question_title,q.question_type,q.difficulty,q.answer,
		 q.analysis,q.score,q.create_user_id,q.sort_order,q.create_time,
		 q.update_time
	</sql>

	<sql id="base_condition_filed">
			<if test="query.questionId != null and query.questionId!=''">
				 and  q.question_id = #{query.questionId}
			</if>
			<if test="query.questionTitle != null and query.questionTitle!=''">
				 and  q.question_title = #{query.questionTitle}
			</if>
			<if test="query.questionType != null">
				 and  q.question_type = #{query.questionType}
			</if>
			<if test="query.difficulty != null">
				 and  q.difficulty = #{query.difficulty}
			</if>
			<if test="query.answer != null and query.answer!=''">
				 and  q.answer = #{query.answer}
			</if>
			<if test="query.analysis != null and query.analysis!=''">
				 and  q.analysis = #{query.analysis}
			</if>
			<if test="query.score != null">
				 and  q.score = #{query.score}
			</if>
			<if test="query.createUserId != null">
				 and  q.create_user_id = #{query.createUserId}
			</if>
			<if test="query.sortOrder != null">
				 and  q.sort_order = #{query.sortOrder}
			</if>
			<if test="query.createTime != null and query.createTime!=''">
				 <![CDATA[ and  q.create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.updateTime != null and query.updateTime!=''">
				 <![CDATA[ and  q.update_time=str_to_date(#{query.updateTime}, '%Y-%m-%d') ]]>
			</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.questionIdFuzzy!= null  and query.questionIdFuzzy!=''">
				 and  q.question_id like concat('%', #{query.questionIdFuzzy}, '%')
			</if>
			<if test="query.questionTitleFuzzy!= null  and query.questionTitleFuzzy!=''">
				 and  q.question_title like concat('%', #{query.questionTitleFuzzy}, '%')
			</if>
			<if test="query.answerFuzzy!= null  and query.answerFuzzy!=''">
				 and  q.answer like concat('%', #{query.answerFuzzy}, '%')
			</if>
			<if test="query.analysisFuzzy!= null  and query.analysisFuzzy!=''">
				 and  q.analysis like concat('%', #{query.analysisFuzzy}, '%')
			</if>
			<if test="query.createTimeStart!= null and query.createTimeStart!=''">
				 <![CDATA[ and  q.create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
				 <![CDATA[ and  q.create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
			<if test="query.updateTimeStart!= null and query.updateTimeStart!=''">
				 <![CDATA[ and  q.update_time>=str_to_date(#{query.updateTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.updateTimeEnd!= null and query.updateTimeEnd!=''">
				 <![CDATA[ and  q.update_time< date_sub(str_to_date(#{query.updateTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
	 </where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM question_info q <include refid="query_condition" />
		 <if test="query.orderBy!=null">
