<mapper namespace="com.smart.campus.mappers.ClassInfoMapper">

	<!--实体映射-->
	<resultMap id="base_result_map" type="com.smart.campus.entity.po.ClassInfo">
		<!---->
		<id column="class_id" property="classId"  />
		<!--班级名称-->
		<result column="class_name" property="className"  />
		<!--班级编码（唯一）-->
		<result column="class_code" property="classCode"  />
		<!--所属专业ID-->
		<result column="major_id" property="majorId"  />
		<!--所属专业名称（关联查询）-->
		<result column="major_name" property="majorName"  />
		<!--所属院系名称（关联查询）-->
		<result column="faculty_name" property="facultyName"  />
		<!--年级（如 2024）-->
		<result column="grade" property="grade"  />
		<!--班级描述-->
		<result column="description" property="description"  />
		<!--排序权重-->
		<result column="sort_order" property="sortOrder"  />
		<!--创建时间-->
		<result column="create_time" property="createTime"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 c.class_id,c.class_name,c.class_code,c.major_id,m.major_name,f.faculty_name,
		 c.grade,c.description,c.sort_order,c.create_time
	</sql>

	<sql id="base_condition_filed">
			<if test="query.classId != null">
				 and  c.class_id = #{query.classId}
			</if>
			<if test="query.className != null and query.className!=''">
				 and  c.class_name = #{query.className}
			</if>
			<if test="query.classCode != null and query.classCode!=''">
				 and  c.class_code = #{query.classCode}
			</if>
			<if test="query.majorId != null">
				 and  c.major_id = #{query.majorId}
			</if>
			<if test="query.facultyId != null">
				 and  m.faculty_id = #{query.facultyId}
			</if>
			<if test="query.grade != null and query.grade!=''">
				 and  c.grade = #{query.grade}
			</if>
			<if test="query.description != null and query.description!=''">
				 and  c.description = #{query.description}
			</if>
			<if test="query.sortOrder != null">
				 and  c.sort_order = #{query.sortOrder}
			</if>
			<if test="query.createTime != null and query.createTime!=''">
				 <![CDATA[ and  c.create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
			</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.classNameFuzzy!= null  and query.classNameFuzzy!=''">
				 and  c.class_name like concat('%', #{query.classNameFuzzy}, '%')
			</if>
			<if test="query.classCodeFuzzy!= null  and query.classCodeFuzzy!=''">
				 and  c.class_code like concat('%', #{query.classCodeFuzzy}, '%')
			</if>
			<if test="query.gradeFuzzy!= null  and query.gradeFuzzy!=''">
				 and  c.grade like concat('%', #{query.gradeFuzzy}, '%')
			</if>
			<if test="query.descriptionFuzzy!= null  and query.descriptionFuzzy!=''">
				 and  c.description like concat('%', #{query.descriptionFuzzy}, '%')
			</if>
			<if test="query.createTimeStart!= null and query.createTimeStart!=''">
				 <![CDATA[ and  c.create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
				 <![CDATA[ and  c.create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
	 </where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM class_info c
		 LEFT JOIN major_info m ON c.major_id = m.major_id
		 LEFT JOIN faculty_info f ON m.faculty_id = f.faculty_id
		 <include refid="query_condition" />
		 <if test="query.orderBy!=null">
			 order by ${query.orderBy}
		 </if>
		 <if test="query.simplePage!=null">
			 limit #{query.simplePage.start},#{query.simplePage.end}
		 </if>
	</select>

	<!-- 查询数量-->
	<select id="selectCount" resultType="java.lang.Integer" >
		 SELECT count(1) FROM class_info c <include refid="query_condition" />
	</select>

